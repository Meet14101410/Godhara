<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Godhara - District HQ</title>
    <style>
        body { font-family: 'Segoe UI', Arial, sans-serif; background: #f4f4f9; display: flex; justify-content: center; padding: 30px; }
        .city-card { background: #fff; width: 450px; border-radius: 10px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); border-left: 8px solid #3498db; overflow: hidden; }
        .header { background: #2c3e50; color: #ecf0f1; padding: 20px; text-align: center; }
        .stats { padding: 25px; line-height: 1.6; }
        .label { font-weight: bold; color: #3498db; }
    </style>
</head>
<body>
    <div class="city-card">
        <div class="header"><h1>🏙️ Godhara</h1><p>Panchmahal District HQ</p></div>
        <div class="stats">
            <p><span class="label">State:</span> Gujarat</p>
            <p><span class="label">Primary Industry:</span> Dairy (Panchamrut), Agriculture</p>
            <p><span class="label">Railway:</span> Major Junction (Western Railway)</p>
            <p><span class="label">Famous Site:</span> Pavagadh/Champaner (Nearby)</p>
            <p><span class="label">Pincode:</span> 389001</p>
        </div>
    </div>
</body>
</html>
